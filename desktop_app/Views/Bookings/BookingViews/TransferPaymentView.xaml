<UserControl x:Class="desktop_app.Views.BookingViews.TransferPaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModel="clr-namespace:desktop_app.ViewModels.Booking"
             xmlns:local="clr-namespace:desktop_app.Views.BookingViews"
             mc:Ignorable="d"
             Style="{StaticResource UserControlBase}"
             DataContext="{x:Static viewModel:TransferPaymentViewModel.Instance}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0 0 22 0">
            <Label Content="Cantidad pagada: " Target="ToPayTextBox" Style="{StaticResource LabelForm}"/>
            <TextBox x:Name="ToPayTextBox" Text="{Binding PricePaid, Mode=TwoWay}" Style="{StaticResource TextBoxForm}"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" Grid.Row="0">
            <Label Content="Total por pagar de la reserva: " Target="TotalToPayTextBox" Style="{StaticResource LabelForm}"/>
            <TextBox x:Name="TotalToPayTextBox" Text="{Binding TotalToPay, Mode=OneWay}" Style="{StaticResource TextBoxForm}" IsEnabled="False"/>
        </StackPanel>
        
        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0 0 22 0">
            <Label Content="Fecha de transferencia: " Target="TransferDatePicker" Style="{StaticResource LabelForm}"/>
            <DatePicker x:Name="TransferDatePicker" SelectedDate="{Binding TransferDate, Mode=TwoWay}" Language="es-Es" Style="{StaticResource DatePickerForm}" Margin="0 0 10 0"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" Grid.Row="1">
            <Label Content="Referencia: " Target="ReferenceTextBox" Style="{StaticResource LabelForm}"/>
            <TextBox x:Name="ReferenceTextBox" Text="{Binding Reference, Mode=TwoWay}" Style="{StaticResource TextBoxForm}"/>
        </StackPanel>
        
        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0 0 22 0">
            <Label Content="Nombre del propietario de cuenta: " Target="HolderTextBox" Style="{StaticResource LabelForm}"/>
            <TextBox x:Name="HolderTextBox" Text="{Binding Holder, Mode=TwoWay}" Style="{StaticResource TextBoxForm}"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" Grid.Row="2">
            <Label Content="Número de cuenta de origen: " Target="AccountTextBox" Style="{StaticResource LabelForm}"/>
            <TextBox x:Name="AccountTextBox" Text="{Binding OriginAccount, Mode=TwoWay}" Style="{StaticResource TextBoxForm}"/>
        </StackPanel>
        
        <StackPanel Grid.Column="0" Grid.Row="3" Orientation="Horizontal" Margin="0 30 0 0">
            <Button Content="Guardar pago" Style="{StaticResource SaveBtn}" Margin="0 0 30 0" Command="{Binding SaveCommand}"/>
        </StackPanel>    
    </Grid>
</UserControl>
