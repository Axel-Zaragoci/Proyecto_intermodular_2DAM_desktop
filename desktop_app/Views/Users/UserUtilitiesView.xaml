<UserControl x:Class="desktop_app.Views.UserUtilitiesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:desktop_app.Views"
        xmlns:viewmodel="clr-namespace:desktop_app.ViewModels.User"
        mc:Ignorable="d" 
        d:DesignHeight="450" d:DesignWidth="800"
        Style="{StaticResource UserControlBase}">
    <UserControl.DataContext>
        <viewmodel:UserUtilitiesMode/>
    </UserControl.DataContext>
    
    
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
            <TextBlock Text="Utilidades" Style="{StaticResource HeaderMainTitle}"/>
        </Border>

        <StackPanel Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <Label Content="Nombre" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.FirstName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <Label Content="Apellido" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0">
                    <Label Content="Email" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2">
                    <Label Content="DNI" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.Dni, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <Label Content="Teléfono" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.PhoneNumber, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2">
                    <Label Content="Ciudad" Style="{StaticResource LabelForm}"/>
                    <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding User.CityName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}"/>
                </StackPanel>
                
                <StackPanel Grid.Row="3" Grid.Column="0">
                    <Label Content="Género" Style="{StaticResource LabelForm}" d:IsLocked="True"/>
                    <ComboBox SelectedValue="{Binding User.Gender}" SelectedValuePath="Content" Style="{StaticResource DropdownStyle}">

                        <ComboBoxItem Content="Hombre"/>
                        <ComboBoxItem Content="Mujer"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="2">
                    <Label Content="Fecha nacimiento" Style="{StaticResource LabelForm}"/>
                    <DatePicker SelectedDate="{Binding User.BirthDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DatePickerForm}"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0">
                    <Label Content="Rol" Style="{StaticResource LabelForm}"/>
                    <ComboBox SelectedValue="{Binding User.Rol}" SelectedValuePath="Content" Style="{StaticResource DropdownStyle}">
                        <ComboBoxItem Content="Usuario"/>
                        <ComboBoxItem Content="Trabajador"/>
                        <ComboBoxItem Content="Admin"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="2">
                    <Label Content="VIP" Style="{StaticResource LabelForm}"/>
                    <CheckBox Content="VIP" IsChecked="{Binding User.VipStatus}" Style="{StaticResource FormCheckBox}"/>
                </StackPanel>
                
                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource ImageBorderForm}" Margin="0 30 12 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="12" Background="#E6F0FF" Margin="0,0,10,0">
                            <Image Source="{Binding ImageRoute}" Width="34" Height="34" Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Foto de perfil" Style="{StaticResource ImageTitle}"/>
                            <TextBlock Text="{Binding ImageLabel}" Style="{StaticResource ImageName}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource ImageButton}"
                                Content="Elegir"
                                Command="{Binding PickImageCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="Cancelar" Style="{StaticResource RedReturnBtn}" Command="{Binding CancelCommand}" CommandParameter="{Binding}" Margin="20,0,0,0"/>
            <Button Content="Guardar" Style="{StaticResource SaveBtn}" Command="{Binding SaveCommand}" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>