<UserControl x:Class="desktop_app.Views.FormBookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:desktop_app.Views"
             xmlns:viewModel="clr-namespace:desktop_app.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" 
             d:DesignWidth="800"
             Style="{StaticResource UserControlBase}"
             DataContext="{x:Static viewModel:FormBookingViewModel.Instance}">
    
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
            <DockPanel LastChildFill="False" VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderMainTitle}"/>
            
                    <Border Style="{StaticResource IdWrapper}">
                        <TextBlock Style="{StaticResource UpdateIdStyle}" Text="{Binding BookingId}"/>
                    </Border>
                </StackPanel>
                    
                <Button Content="Volver" Style="{StaticResource HeaderNavigateButton}" Command="{Binding ReturnCommand}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
        
        <DockPanel  Grid.Row="1" LastChildFill="False">
            <StackPanel Style="{StaticResource BtnWrapper}" DockPanel.Dock="Left">
                    
            </StackPanel>
            
            <StackPanel DockPanel.Dock="Right">
                <Button x:Name="MenuButton" 
                        Style="{StaticResource DropdownExtrasMenu}" 
                        Content="more_horiz" 
                        ToolTip="Más opciones"
                        Click="MenuButton_Click">
        
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource DropdownContextMenuStyle}">
                            <MenuItem Header="Factura" Style="{StaticResource DropdownMenuItemStyle}" Command="{Binding DownloadInvoiceCommand}"/>
                            <MenuItem Header="Cancelar reserva" Style="{StaticResource DropdownMenuItemStyle}" Command="{Binding CancelBookingCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </DockPanel>
        
        
        <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="0 10 0 0"/>
    </Grid>
</UserControl>
